generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 🚩 สร้างยศให้ระบบ
enum Role {
  USER
  VIP
  STAFF
  ADMIN
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String?  // ชื่อผู้สมัคร หรือ ชื่อทีม
  role        Role     @default(USER) // สมัครใหม่เป็น USER ธรรมดาเสมอ
  createdAt   DateTime @default(now())
  drivers     Driver[] // User 1 คน มีนักแข่งในการดูแลได้ (ถ้าเป็น VIP จะมีหลายคน)
}

model Driver {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  birthDate     DateTime
  
  // 🚩 --- ข้อมูลนักแข่งเพิ่มเติม (RMCAT) ---
  nickname      String?
  nationality   String?
  licenseNo     String?
  licenseImageUrl String? @db.Text
  shirtSize     String?
  bloodType     String?
  mobileNo      String?
  
  // 🚩 --- ข้อมูลผู้ปกครอง (กรณีอายุไม่ถึง 18) ---
  guardianName        String?
  guardianId          String?  // NRIC/FIN/Passport/ID
  guardianNationality String?
  guardianMobile      String?

  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  registrations Registration[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
}

model Event {
  id             String   @id
  name           String
  location       String
  startDate      DateTime
  endDate        DateTime
  isDoubleHeader Boolean  @default(false) // 🚩 ระบุว่าเป็นสนามควบ TH+ASIA หรือไม่
  registrations  Registration[]
}

model Registration {
  id            String   @id @default(cuid())
  driverId      String
  eventId       String
  category      String   // รุ่นหลัก เช่น Micro MAX
  crossEntry    String?  // รุ่นควบ เช่น Micro Rookie
  racingNumber  Int
  paymentStatus String   @default("PENDING")
  createdAt     DateTime @default(now())

  driver        Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// 🚩 ตารางใหม่ สำหรับให้ Admin แก้ข้อความหน้าเว็บ
model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique // เช่น "WELCOME_TITLE", "ANNOUNCEMENT"
  value       String   // ข้อความที่จะโชว์
  updatedAt   DateTime @updatedAt
}