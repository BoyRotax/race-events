generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // หรือ mysql ตามที่นายใช้ใน .env
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      String   @default("USER")
  drivers   Driver[]
  createdAt DateTime @default(now())
}

model Driver {
  id                String         @id @default(cuid())
  firstName         String
  lastName          String
  nickname          String?
  birthDate         DateTime
  nationality       String?
  licenseNo         String?
  licenseImageUrl   String?        @db.Text
  bloodType         String?
  shirtSize         String?
  mobileNo          String?
  guardianName      String?
  guardianId        String?
  guardianNationality String?
  guardianMobile    String?
  user              User           @relation(fields: [userId], references: [id])
  userId            String
  registrations     Registration[]
  createdAt         DateTime       @default(now())
}

model Registration {
  id            String   @id @default(cuid())
  driver        Driver   @relation(fields: [driverId], references: [id])
  driverId      String
  eventId       String   // เช่น TH-R1
  category      String   // เช่น Micro MAX
  racingNumber  String
  paymentStatus String   @default("PENDING")
  slipImageUrl  String?  @db.Text
  createdAt     DateTime @default(now())
}